---
import {
  ArrowRight,
  ChartColumn,
  BookOpenCheck,
  Check,
  ChevronDown,
  ClipboardCheck,
  CloudCog,
  Database,
  GraduationCap,
  HeartHandshake,
  Landmark,
  LayoutDashboard,
  MessageSquareText,
  School,
  ShieldCheck,
  Sparkles,
  Users,
} from "@lucide/astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductDashboard from "../components/ProductDashboard.astro";
import { faqs, products, roadmap, serviceModels } from "../data/site";

const softwareJsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "IhsanCloud",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "IDR",
    description: "Fitur inti tersedia gratis bagi lembaga yang memenuhi ketentuan program.",
  },
};

const problems = [
  "Data tersebar di banyak spreadsheet",
  "Pekerjaan administratif terus berulang",
  "Laporan terlambat dan sulit dirangkum",
  "Komunikasi penting tidak terdokumentasi",
  "Pergantian pengurus mengganggu kesinambungan",
  "Pimpinan sulit melihat kondisi menyeluruh",
];

const onboarding = [
  ["01", "Ajukan lembaga", "Lengkapi profil dan kebutuhan utama lembaga."],
  ["02", "Asesmen", "Kami meninjau kesiapan, pengguna, dan modul prioritas."],
  ["03", "Aktivasi", "Dapatkan ruang kerja, akun admin, dan panduan awal."],
  ["04", "Konfigurasi", "Masukkan data secara mandiri atau dengan pendampingan."],
  ["05", "Pelatihan", "Orientasi bagi operator dan pengguna utama."],
  ["06", "Gunakan bertahap", "Mulai dari kebutuhan terpenting, lalu tumbuh saat siap."],
];
---

<BaseLayout
  title="IhsanCloud — Sistem Informasi Gratis untuk Lembaga Pendidikan dan Dakwah"
  description="Sistem informasi gratis berbasis cloud untuk ma’had, pesantren, TPQ, masjid, yayasan, dan lembaga dakwah yang terus dijaga, didampingi, dan dikembangkan."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(softwareJsonLd)} />

  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <div class="eyebrow">Sistem informasi inti gratis • Berbasis cloud</div>
        <h1 class="display hero-title">Sistem informasi gratis untuk Ma’had, Pesantren, TPQ, Masjid, Yayasan, dan Lembaga Dakwah.</h1>
        <p class="hero-lead">
          Dibangun untuk ma’had, pesantren, TPQ, rumah Qur’an, masjid, yayasan, dan lembaga dakwah lainnya—agar data, pembelajaran, administrasi, SDM, jamaah, serta program dapat dikelola dalam satu ekosistem.
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href="/daftar">Daftarkan Lembaga <ArrowRight size={17} /></a>
          <a class="button button-secondary" href="/donasi">Jadi Donatur Tetap</a>
        </div>
        <p class="microcopy"><Sparkles size={15} /> Teknologinya gratis. Keberlanjutannya dijaga bersama.</p>
      </div>
      <div class="hero-visual">
        <div class="visual-note"><span>01</span> Ruang kerja lembaga yang mudah dipahami</div>
        <ProductDashboard />
      </div>
    </div>
  </section>

  <section class="section commitment-section">
    <div class="container commitment-grid">
      <div class="commitment-heading">
        <div class="eyebrow">Lebih dari sekadar membuat aplikasi</div>
        <h2>Membuat sistem adalah awal. Menjaga manfaatnya adalah amanah jangka panjang.</h2>
      </div>
      <div class="commitment-copy">
        <blockquote>
          “Banyak orang sekarang bisa membuat aplikasi atau sistem informasi. Namun untuk menjaga, mendukung, mendampingi, melatih, dan terus mengembangkannya sesuai kebutuhan—tidak semua mampu.”
        </blockquote>
        <p>Karena itu IhsanCloud hadir bukan sebagai proyek sekali jadi, melainkan sebagai layanan yang tumbuh bersama kebutuhan lembaga.</p>
      </div>
    </div>
    <div class="container commitment-steps" aria-label="Komitmen keberlanjutan IhsanCloud">
      {["Menjaga", "Mendukung", "Mendampingi", "Melatih", "Mengembangkan"].map((item, index) => (
        <div><span>{String(index + 1).padStart(2, "0")}</span><strong>{item}</strong></div>
      ))}
    </div>
  </section>

  <section id="tentang" class="section value-section">
    <div class="container">
      <div class="value-intro">
        <div>
          <div class="eyebrow">Mengapa IhsanCloud</div>
          <h2 class="heading">Satu sistem, banyak penerima manfaat.</h2>
        </div>
        <p class="lead">Ketika tata kelola lembaga lebih tertib, guru dapat lebih fokus mengajar, pimpinan memperoleh informasi yang lebih baik, orang tua lebih mudah terhubung, dan data lembaga tidak lagi bergantung pada satu orang.</p>
      </div>
      <div class="principles">
        <article><span>01</span><h3>Mudah digunakan</h3><p>Dirancang untuk beragam tingkat kemampuan digital.</p></article>
        <article><span>02</span><h3>Terintegrasi</h3><p>Data dan proses kerja bertemu dalam satu ruang.</p></article>
        <article><span>03</span><h3>Amanah</h3><p>Hak akses jelas dan aktivitas lebih mudah ditelusuri.</p></article>
        <article><span>04</span><h3>Berkelanjutan</h3><p>Dijaga bersama lembaga, donatur, dan mitra.</p></article>
      </div>
    </div>
  </section>

  <section class="section problem-section">
    <div class="container problem-grid">
      <div class="problem-copy">
        <div class="eyebrow">Tantangan lembaga</div>
        <h2 class="heading">Lembaga bertumbuh. Sistem kerjanya belum tentu ikut bertumbuh.</h2>
        <p class="lead">Data siswa tersimpan di banyak file. Absensi dikirim melalui grup pesan. Ketika operator atau pengurus berganti, sebagian pengetahuan lembaga ikut hilang.</p>
      </div>
      <div class="problem-list">
        {problems.map((problem, index) => (
          <div><span>{String(index + 1).padStart(2, "0")}</span><p>{problem}</p></div>
        ))}
      </div>
    </div>
    <div class="container answer-line">
      <span aria-hidden="true"></span>
      <p>IhsanCloud menyatukan data dan proses kerja <strong>tanpa memaksa lembaga mengubah semuanya dalam satu waktu.</strong></p>
    </div>
  </section>

  <section id="solusi" class="section solutions-section">
    <div class="container">
      <div class="section-head">
        <div>
          <div class="eyebrow">Solusi modular</div>
          <h2 class="heading">Satu fondasi untuk berbagai lembaga.</h2>
        </div>
        <p class="lead">Aktifkan modul sesuai kebutuhan dan kesiapan. Mulai sederhana, lalu berkembang tanpa memindahkan data ke sistem baru.</p>
      </div>
      <div class="product-selector" data-product-selector>
        <div class="product-tabs" role="tablist" aria-label="Pilih jenis lembaga">
          {products.map((product, index) => (
            <button
              type="button"
              id={`tab-${product.id}`}
              role="tab"
              aria-selected={index === 0 ? "true" : "false"}
              aria-controls={`panel-${product.id}`}
              tabindex={index === 0 ? 0 : -1}
              data-tab={product.id}
            >
              {product.label}
            </button>
          ))}
        </div>
        {products.map((product, index) => (
          <div
            class="product-panel"
            id={`panel-${product.id}`}
            role="tabpanel"
            aria-labelledby={`tab-${product.id}`}
            hidden={index !== 0}
            data-panel={product.id}
          >
            <div class="product-name">
              <span>{String(index + 1).padStart(2, "0")}</span>
              <h3>{product.name}</h3>
              <p>{product.description}</p>
            </div>
            <ul>
              {product.features.map((feature) => <li><Check size={15} /> {feature}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="produk" class="section product-tour">
    <div class="container tour-grid">
      <div class="tour-copy">
        <div class="eyebrow">Product tour</div>
        <h2 class="heading">Mudah digunakan operator, mudah dipahami pimpinan.</h2>
        <p class="lead">Setiap peran melihat informasi yang relevan. Operator tahu apa yang harus ditindaklanjuti. Pimpinan memperoleh ringkasan tanpa membuka banyak laporan.</p>
        <div class="tour-switches" role="list">
          <div role="listitem"><LayoutDashboard size={19} /><span><strong>Dashboard operasional</strong><small>Tugas, kehadiran, data belum lengkap</small></span></div>
          <div role="listitem"><ChartColumn size={19} /><span><strong>Dashboard pimpinan</strong><small>Perkembangan, kondisi program, risiko</small></span></div>
          <div role="listitem"><Users size={19} /><span><strong>Portal pengguna</strong><small>Guru, orang tua, santri, jamaah</small></span></div>
        </div>
      </div>
      <ProductDashboard />
    </div>
  </section>

  <section class="section free-section">
    <div class="container free-grid">
      <div class="free-main">
        <div class="eyebrow">Akses teknologi untuk lembaga</div>
        <h2 class="heading">Software gratis agar lembaga bertumbuh tanpa terhalang biaya lisensi.</h2>
        <p class="lead">Fitur inti disediakan gratis karena teknologi yang tertata seharusnya dapat membantu lebih banyak lembaga meningkatkan mutu tata kelola dan pelayanan.</p>
        <div class="license-note"><Check size={20} /><strong>Tidak ada biaya lisensi untuk fitur inti.</strong></div>
      </div>
      <aside class="cost-note">
        <CloudCog size={27} />
        <h3>Gratis bukan berarti tanpa biaya operasional.</h3>
        <p>Server, penyimpanan, keamanan, pemeliharaan, dokumentasi, dukungan, dan pengembangan tetap perlu dijaga.</p>
        <p class="fine">Migrasi data, implementasi, pelatihan khusus, integrasi, dukungan prioritas, dan pengembangan fitur khusus dapat menjadi layanan berbayar.</p>
      </aside>
    </div>
  </section>

  <section class="section donor-section">
    <div class="container donor-grid">
      <div>
        <div class="eyebrow donor-eyebrow">Sahabat IhsanCloud</div>
        <h2 class="heading">Mari menjaga IhsanCloud tetap hidup dan bermanfaat.</h2>
      </div>
      <div>
        <p class="donor-lead">Dukungan rutin membantu kami menjaga layanan tetap aktif, stabil, aman, dan terus berkembang—agar lembaga dapat fokus mendidik dan melayani.</p>
        <div class="donor-actions">
          <a class="button button-light" href="/donasi">Jadi Donatur Tetap <ArrowRight size={17} /></a>
          <a class="button button-ghost-light" href="/keberlanjutan">Lihat Penggunaan Donasi</a>
        </div>
      </div>
    </div>
    <div class="container donation-uses">
      <div><CloudCog size={20} /><span>Server & infrastruktur</span></div>
      <div><Database size={20} /><span>Database & penyimpanan</span></div>
      <div><ShieldCheck size={20} /><span>Backup & keamanan</span></div>
      <div><BookOpenCheck size={20} /><span>Dokumentasi & pelatihan</span></div>
      <div><HeartHandshake size={20} /><span>Pendampingan lembaga</span></div>
      <div><CloudCog size={20} /><span>Pengembangan produk</span></div>
    </div>
  </section>

  <section id="dampak" class="section impact-section">
    <div class="container">
      <div class="impact-intro">
        <div class="eyebrow">Dampak yang meluas</div>
        <h2 class="heading">Donasi Anda tidak berhenti pada biaya server.</h2>
        <p class="lead">Satu dukungan dapat membantu banyak lembaga, banyak pengajar, dan ribuan keluarga—tanpa mengada-adakan angka dampak sebelum datanya tersedia.</p>
      </div>
      <div class="impact-flow" aria-label="Alur dampak dukungan">
        <article><span>01</span><h3>Dukungan operasional</h3><p>Individu, keluarga, lembaga, dan perusahaan menjaga keberlanjutan layanan.</p></article>
        <ArrowRight class="flow-arrow" size={26} aria-hidden="true" />
        <article><span>02</span><h3>Teknologi yang terjaga</h3><p>Infrastruktur, pemeliharaan, pengembangan, dan pendampingan terus berjalan.</p></article>
        <ArrowRight class="flow-arrow" size={26} aria-hidden="true" />
        <article><span>03</span><h3>Pelayanan yang membaik</h3><p>Pengelola, pengajar, peserta didik, orang tua, jamaah, dan masyarakat merasakan manfaat.</p></article>
      </div>
    </div>
  </section>

  <section class="section support-section">
    <div class="container">
      <div class="section-head">
        <div>
          <div class="eyebrow">Bentuk dukungan</div>
          <h2 class="heading">Banyak jalan untuk ikut menjaga manfaat.</h2>
        </div>
        <p class="lead">Dukungan dapat berupa donasi rutin, sponsor lembaga, infrastruktur, keahlian, pelatihan, maupun pendampingan di berbagai daerah.</p>
      </div>
      <div class="support-grid">
        <article class="support-featured">
          <HeartHandshake size={28} />
          <div><span>Donatur tetap</span><h3>Mulai dari Rp25.000 per bulan</h3><p>Dukungan rutin untuk operasional, pemeliharaan, dan pengembangan IhsanCloud.</p></div>
          <a href="/donasi">Pilih dukungan <ArrowRight size={16} /></a>
        </article>
        <article><Landmark size={22} /><h3>Sponsor satu lembaga</h3><p>Bantu aktivasi, pelatihan, dan pendampingan lembaga.</p></article>
        <article><CloudCog size={22} /><h3>Mitra infrastruktur</h3><p>Dukung server, database, monitoring, dan backup.</p></article>
        <article><ClipboardCheck size={22} /><h3>Mitra implementasi</h3><p>Dampingi konfigurasi dan penggunaan di berbagai daerah.</p></article>
        <article><GraduationCap size={22} /><h3>Mitra pelatihan</h3><p>Perkuat operator, guru, pengurus, dan tenaga kependidikan.</p></article>
      </div>
    </div>
  </section>

  <section class="section transparency-section">
    <div class="container transparency-grid">
      <div>
        <div class="eyebrow">Transparansi</div>
        <h2 class="heading">Dikelola secara terbuka dan bertanggung jawab.</h2>
        <p class="lead">Laporan berkala akan membantu donatur dan mitra memahami bagaimana dukungan digunakan dan manfaat apa yang telah dihasilkan.</p>
        <a class="button button-secondary" href="/keberlanjutan">Lihat Laporan Keberlanjutan</a>
      </div>
      <div class="report-preview">
        <div class="report-top"><span>Laporan keberlanjutan</span><b>Format laporan</b></div>
        <div class="report-row"><span>Operasional infrastruktur</span><i></i></div>
        <div class="report-row"><span>Pemeliharaan & keamanan</span><i></i></div>
        <div class="report-row"><span>Pengembangan produk</span><i></i></div>
        <div class="report-row"><span>Pelatihan & pendampingan</span><i></i></div>
        <p>Data akan dipublikasikan setelah program berjalan dan diverifikasi. Tidak ada angka simulasi yang ditampilkan sebagai fakta.</p>
      </div>
    </div>
  </section>

  <section class="section onboarding-section">
    <div class="container">
      <div class="section-head">
        <div>
          <div class="eyebrow">Cara memulai</div>
          <h2 class="heading">Bertahap, sesuai kesiapan lembaga.</h2>
        </div>
        <p class="lead">Mulai dari modul paling penting. Tim dapat menambah kebutuhan lain setelah alur kerja utama sudah stabil.</p>
      </div>
      <div class="steps">
        {onboarding.map(([number, title, text]) => (
          <article><span>{number}</span><div><h3>{title}</h3><p>{text}</p></div></article>
        ))}
      </div>
    </div>
  </section>

  <section class="section model-section">
    <div class="container">
      <div class="eyebrow">Model layanan</div>
      <h2 class="heading">Mulai sesuai kebutuhan dan kesiapan lembaga.</h2>
      <div class="model-grid">
        {serviceModels.map((model, index) => (
          <article class:list={{ recommended: index === 0 }}>
            <span>{index === 0 ? "Fitur inti gratis" : `0${index + 1}`}</span>
            <h3>{model.name}</h3>
            <p>{model.description}</p>
            <ul>{model.items.map((item) => <li><Check size={14} /> {item}</li>)}</ul>
            <a href={model.href}>{model.cta} <ArrowRight size={15} /></a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section benefit-section">
    <div class="container">
      <div class="benefit-top">
        <div>
          <div class="eyebrow">Manfaat nyata</div>
          <h2 class="heading">Lebih banyak ruang untuk mendidik dan melayani.</h2>
        </div>
        <p class="lead">Administrasi yang lebih tertib bukan tujuan akhir. Ia memberi waktu, perhatian, dan informasi yang lebih baik bagi seluruh penerima manfaat.</p>
      </div>
      <div class="benefit-list">
        <article><School size={22} /><span>Lembaga</span><h3>Tata kelola lebih tertib, data terpusat, keputusan lebih terinformasi.</h3></article>
        <article><BookOpenCheck size={22} /><span>Pengajar</span><h3>Pencatatan lebih mudah, komunikasi lebih terstruktur, fokus mengajar bertambah.</h3></article>
        <article><GraduationCap size={22} /><span>Peserta didik</span><h3>Perkembangan lebih terpantau dan pelayanan lebih personal.</h3></article>
        <article><MessageSquareText size={22} /><span>Orang tua & jamaah</span><h3>Informasi lebih mudah diperoleh dan tidak lagi tercecer.</h3></article>
      </div>
    </div>
  </section>

  <section class="section roadmap-section">
    <div class="container">
      <div class="section-head">
        <div>
          <div class="eyebrow">Roadmap transparan</div>
          <h2 class="heading">Dibangun bertahap bersama lembaga pengguna.</h2>
        </div>
        <p class="lead">Status fitur ditampilkan apa adanya. Daftar dapat berubah mengikuti validasi kebutuhan dan kapasitas pengembangan.</p>
      </div>
      <div class="roadmap-grid">
        {roadmap.map((column) => (
          <article>
            <div class:list={["status", column.tone]}><span></span>{column.status}</div>
            <ul>{column.items.map((item) => <li>{item}</li>)}</ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="faq" class="section faq-section">
    <div class="container faq-grid">
      <div>
        <div class="eyebrow">Pertanyaan umum</div>
        <h2 class="heading">Hal yang perlu Anda ketahui.</h2>
        <p class="lead">Belum menemukan jawaban? Sampaikan kebutuhan lembaga Anda melalui formulir pendaftaran.</p>
        <a class="button button-secondary" href="/daftar">Ajukan Pertanyaan</a>
      </div>
      <div class="faq-list">
        {faqs.map((faq, index) => (
          <details open={index === 0}>
            <summary>{faq.q}<ChevronDown size={18} /></summary>
            <p>{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="final-cta">
    <div class="container final-grid">
      <div>
        <span class="final-kicker">Dua jalan, satu tujuan</span>
        <h2>Mari membangun layanan digital yang terus hidup dan memberi manfaat.</h2>
      </div>
      <div>
        <p>Daftarkan lembaga Anda atau jadilah donatur tetap agar semakin banyak lembaga memperoleh akses terhadap teknologi yang baik.</p>
        <div class="hero-actions">
          <a class="button button-light" href="/daftar">Daftarkan Lembaga <ArrowRight size={17} /></a>
          <a class="button button-ghost-light" href="/donasi">Jadi Donatur Tetap</a>
        </div>
        <small>Teknologinya gratis. Keberlanjutannya kita jaga bersama.</small>
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll<HTMLElement>("[data-product-selector]").forEach((selector) => {
      const tabs = Array.from(selector.querySelectorAll<HTMLButtonElement>("[data-tab]"));
      const panels = Array.from(selector.querySelectorAll<HTMLElement>("[data-panel]"));

      const selectTab = (tab: HTMLButtonElement) => {
        tabs.forEach((item) => {
          const selected = item === tab;
          item.setAttribute("aria-selected", String(selected));
          item.tabIndex = selected ? 0 : -1;
        });
        panels.forEach((panel) => {
          panel.hidden = panel.dataset.panel !== tab.dataset.tab;
        });
      };

      tabs.forEach((tab, index) => {
        tab.addEventListener("click", () => selectTab(tab));
        tab.addEventListener("keydown", (event) => {
          if (!["ArrowLeft", "ArrowRight", "Home", "End"].includes(event.key)) return;
          event.preventDefault();
          let next = index;
          if (event.key === "ArrowRight") next = (index + 1) % tabs.length;
          if (event.key === "ArrowLeft") next = (index - 1 + tabs.length) % tabs.length;
          if (event.key === "Home") next = 0;
          if (event.key === "End") next = tabs.length - 1;
          selectTab(tabs[next]);
          tabs[next].focus();
        });
      });
    });
  </script>
</BaseLayout>

<style>
  .hero {
    overflow: hidden;
    padding-block: clamp(4.5rem, 7.5vw, 7.8rem) clamp(5rem, 8vw, 8.5rem);
    background: linear-gradient(115deg, rgba(233, 225, 210, 0.52), transparent 48%);
  }

  .hero-grid {
    display: grid;
    align-items: center;
    gap: 4rem;
  }

  .hero-copy {
    position: relative;
    z-index: 2;
  }

  .hero-title {
    max-width: 13ch;
    font-size: clamp(2.55rem, 5.45vw, 5.25rem);
  }

  .hero-lead {
    max-width: 62ch;
    margin: 1.7rem 0 0;
    color: #4f5a53;
    font-size: clamp(1.05rem, 1.6vw, 1.22rem);
    line-height: 1.75;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.72rem;
    margin-top: 2rem;
  }

  .microcopy {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 1.1rem 0 0;
    color: #6a746e;
    font-size: 0.8rem;
  }

  .visual-note {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin: 0 0 0.85rem 1rem;
    color: #68746c;
    font-size: 0.73rem;
    font-weight: 700;
  }

  .visual-note span {
    color: var(--gold);
    font-family: "Manrope Variable", sans-serif;
  }

  .commitment-section {
    background: var(--olive);
    color: var(--ivory);
  }

  .commitment-grid {
    display: grid;
