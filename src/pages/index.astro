    margin: 0;
    color: var(--muted);
    font-size: 0.86rem;
  }

  .model-grid ul {
    display: grid;
    gap: 0.55rem;
    margin: 1.5rem 0;
    padding: 1.2rem 0;
    border-block: 1px solid var(--line);
    list-style: none;
  }

  .model-grid li {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    color: #4e5a52;
    font-size: 0.8rem;
  }

  .model-grid a {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--forest);
    font-size: 0.8rem;
    font-weight: 800;
  }

  .benefit-section {
    background: var(--olive);
    color: var(--ivory);
  }

  .benefit-section .heading {
    color: var(--ivory);
  }

  .benefit-section .lead {
    color: rgba(247, 244, 236, 0.7);
  }

  .benefit-list {
    display: grid;
    margin-top: 4rem;
    border-top: 1px solid rgba(247, 244, 236, 0.18);
  }

  .benefit-list article {
    display: grid;
    grid-template-columns: 2rem 1fr;
    gap: 0 1rem;
    border-bottom: 1px solid rgba(247, 244, 236, 0.18);
    padding: 1.4rem 0;
  }

  .benefit-list :global(svg) {
    grid-row: 1 / 3;
    color: #d4bb76;
  }

  .benefit-list span {
    color: #d4bb76;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .benefit-list h3 {
    margin: 0.4rem 0 0;
    max-width: 42rem;
    color: var(--ivory);
    font-family: "Manrope Variable", sans-serif;
    font-size: clamp(1.1rem, 2vw, 1.55rem);
    font-weight: 550;
  }

  .roadmap-section {
    background: #fffdf8;
  }

  .roadmap-grid {
    display: grid;
    gap: 0.8rem;
    margin-top: 3rem;
  }

  .roadmap-grid article {
    border: 1px solid var(--line);
    padding: 1.4rem;
  }

  .status {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    border-bottom: 1px solid var(--line);
    padding-bottom: 1rem;
    color: var(--olive);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .status span {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
  }

  .available span { background: #47785b; }
  .development span { background: var(--gold); }
  .planned span { background: #9aa19c; }

  .roadmap-grid ul {
    display: grid;
    gap: 0.65rem;
    margin: 1.2rem 0 0;
    padding: 0;
    list-style: none;
  }

  .roadmap-grid li {
    color: #536058;
    font-size: 0.84rem;
  }

  .roadmap-grid li::before {
    margin-right: 0.55rem;
    color: var(--gold);
    content: "—";
  }

  .faq-section {
    background: var(--ivory);
  }

  .faq-grid {
    display: grid;
    gap: 4rem;
  }

  .faq-grid .lead {
    margin: 1.5rem 0;
  }

  .faq-list {
    border-top: 1px solid var(--line);
  }

  details {
    border-bottom: 1px solid var(--line);
  }

  summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.15rem 0;
    cursor: pointer;
    color: var(--olive);
    font-family: "Manrope Variable", sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    list-style: none;
  }

  summary::-webkit-details-marker {
    display: none;
  }

  summary :global(svg) {
    flex: 0 0 auto;
    transition: transform 180ms ease;
  }

  details[open] summary :global(svg) {
    transform: rotate(180deg);
  }

  details p {
    margin: -0.3rem 0 1.2rem;
    padding-right: 2rem;
    color: var(--muted);
    font-size: 0.86rem;
  }

  .final-cta {
    background: var(--forest);
    color: var(--ivory);
    padding-block: clamp(4rem, 8vw, 7rem);
  }

  .final-grid {
    display: grid;
    gap: 2.5rem;
  }

  .final-kicker {
    color: #d7c184;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .final-cta h2 {
    margin: 1rem 0 0;
    max-width: 18ch;
    font-family: "Manrope Variable", sans-serif;
    font-size: clamp(2.2rem, 5vw, 4.5rem);
    line-height: 1.03;
    letter-spacing: -0.045em;
  }

  .final-cta p {
    margin: 0;
    color: rgba(247, 244, 236, 0.72);
    font-size: 1.05rem;
  }

  .final-cta small {
    display: block;
    margin-top: 1rem;
    color: rgba(247, 244, 236, 0.58);
  }

  @media (min-width: 720px) {
    .value-intro,
    .section-head,
    .benefit-top,
    .donor-grid,
    .final-grid {
      grid-template-columns: 1.15fr 0.85fr;
      align-items: end;
      gap: 4rem;
    }

    .principles {
      grid-template-columns: repeat(4, 1fr);
    }

    .principles article {
      grid-template-columns: 1fr;
      border-right: 1px solid var(--line);
      padding: 1.5rem;
    }

    .principles article:first-child {
      padding-left: 0;
    }

    .principles article:last-child {
      border-right: 0;
    }

    .principles span {
      grid-row: auto;
    }

    .principles h3 {
      margin-top: 2.2rem;
    }

    .product-panel {
      grid-template-columns: 0.9fr 1.1fr;
      align-items: center;
    }

    .donation-uses {
      grid-template-columns: repeat(3, 1fr);
    }

    .impact-flow {
      grid-template-columns: 1fr auto 1fr auto 1fr;
    }

    .flow-arrow {
      transform: none;
    }

    .support-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .support-featured {
      grid-column: 1 / -1;
      grid-template-columns: auto 1fr auto;
      align-items: center;
    }

    .steps {
      grid-template-columns: repeat(2, 1fr);
    }

    .steps article:nth-child(odd) {
      border-right: 1px solid var(--line);
      padding-right: 2rem;
    }

    .steps article:nth-child(even) {
      padding-left: 2rem;
    }

    .model-grid,
    .roadmap-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .commitment-steps {
      grid-template-columns: repeat(5, 1fr);
    }
  }

  @media (min-width: 980px) {
    .hero-grid {
      grid-template-columns: minmax(0, 0.88fr) minmax(520px, 1.12fr);
      gap: 2rem;
    }

    .hero-visual {
      margin-right: -12%;
    }

    .commitment-grid {
      grid-template-columns: 1fr 1fr;
      align-items: start;
      gap: clamp(4rem, 8vw, 8rem);
    }

    .problem-grid,
    .tour-grid,
    .free-grid,
    .transparency-grid,
    .faq-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: clamp(4rem, 8vw, 8rem);
    }

    .support-grid {
      grid-template-columns: repeat(4, 1fr);
    }

    .support-featured {
      grid-column: 1 / span 2;
      grid-row: 1 / span 2;
      grid-template-columns: 1fr;
      align-content: space-between;
      padding: 2rem;
    }

    .support-featured h3 {
      font-size: 2rem;
    }

