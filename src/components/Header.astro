---
import { Building2, HeartHandshake, House, Layers, LogIn } from "@lucide/astro";
import Logo from "./Logo.astro";

const pathname = Astro.url.pathname;
const mobileItems = [
  { label: "Beranda", href: "/", icon: House, active: pathname === "/" },
  { label: "Solusi", href: "/#solusi", icon: Layers, active: false },
  { label: "Daftar", href: "/daftar", icon: Building2, active: pathname === "/daftar" || pathname === "/daftar/" },
  { label: "Donasi", href: "/donasi", icon: HeartHandshake, active: pathname === "/donasi" || pathname === "/donasi/" },
  { label: "Masuk", href: "https://app.ihsancloud.id", icon: LogIn, active: false },
];
---

<div class="announcement">
  <div class="container">
    <span>Program lembaga perintis IhsanCloud telah dibuka.</span>
    <a href="/daftar">Ajukan lembaga <span aria-hidden="true">→</span></a>
  </div>
</div>

<header class="site-header">
  <div class="container nav-shell">
    <Logo />
    <nav class="desktop-nav" aria-label="Navigasi utama">
      <a href="/#tentang">Tentang</a>
      <a href="/#solusi">Solusi</a>
      <a href="/#produk">Produk</a>
      <a href="/#dampak">Dampak</a>
      <a href="/keberlanjutan">Keberlanjutan</a>
      <a href="/#faq">FAQ</a>
    </nav>
    <div class="desktop-actions">
      <a class="login" href="https://app.ihsancloud.id">Masuk</a>
      <a class="button button-primary" href="/daftar">Daftarkan Lembaga</a>
      <a class="donate-link" href="/donasi">Jadi Donatur</a>
    </div>
    <a class="mobile-donate" href="/donasi">Jadi Donatur</a>
  </div>
</header>

<nav class="mobile-bottom-nav" aria-label="Navigasi utama seluler">
  {mobileItems.map(({ label, href, icon: Icon, active }) => (
    <a class:list={{ primary: label === "Daftar", active }} href={href} aria-current={active ? "page" : undefined}>
      <span class="mobile-icon"><Icon size={19} stroke-width={1.9} aria-hidden="true" /></span>
      <span>{label}</span>
    </a>
  ))}
</nav>

<style>
  .announcement {
    background: var(--olive);
    color: var(--ivory);
    font-size: 0.78rem;
  }

  .announcement .container {
    display: flex;
    min-height: 38px;
    align-items: center;
    justify-content: center;
    gap: 0.7rem 1.1rem;
    text-align: center;
  }

  .announcement a {
    color: #e4c985;
    font-weight: 750;
    white-space: nowrap;
  }

  .site-header {
    position: sticky;
    z-index: 50;
    top: 0;
    border-bottom: 1px solid var(--line);
    background: rgba(247, 244, 236, 0.94);
    backdrop-filter: blur(14px);
  }

  .nav-shell {
    display: flex;
    min-height: 68px;
    align-items: center;
    justify-content: space-between;
    gap: 1.2rem;
  }

  .desktop-nav,
  .desktop-actions {
    display: none;
  }

  .mobile-donate {
    border-bottom: 1px solid #8a703b;
    color: #765f2e;
    font-size: 0.72rem;
    font-weight: 800;
  }

  .mobile-bottom-nav {
    position: fixed;
    z-index: 70;
    right: 0;
    bottom: 0;
    left: 0;
    display: grid;
    min-height: 68px;
    grid-template-columns: repeat(5, 1fr);
    align-items: end;
    border-top: 1px solid rgba(38, 55, 45, 0.15);
    background: rgba(255, 253, 248, 0.96);
    padding: 0.45rem 0.35rem max(0.4rem, env(safe-area-inset-bottom));
    box-shadow: 0 -12px 34px rgba(31, 47, 38, 0.12);
    backdrop-filter: blur(16px);
  }

  .mobile-bottom-nav a {
    display: grid;
    min-width: 0;
    justify-items: center;
    gap: 0.2rem;
    color: #6d766f;
    font-size: 0.61rem;
    font-weight: 700;
    line-height: 1;
  }

  .mobile-bottom-nav a.active {
    color: var(--olive);
  }

  .mobile-icon {
    display: grid;
    width: 34px;
    height: 30px;
    place-items: center;
    border-radius: 0.65rem;
  }

  .mobile-bottom-nav a.active .mobile-icon {
    background: rgba(38, 55, 45, 0.09);
  }

  .mobile-bottom-nav a.primary {
    color: var(--olive);
  }

  .mobile-bottom-nav a.primary .mobile-icon {
    width: 46px;
    height: 46px;
    margin-top: -1.15rem;
    border: 4px solid var(--ivory);
    border-radius: 50%;
    background: var(--olive);
    color: var(--ivory);
    box-shadow: 0 8px 20px rgba(38, 55, 45, 0.26);
  }

  @media (min-width: 980px) {
    .nav-shell {
      min-height: 76px;
    }

    .desktop-nav,
    .desktop-actions {
      display: flex;
      align-items: center;
    }

    .desktop-nav {
      gap: clamp(0.85rem, 1.6vw, 1.6rem);
      margin-left: auto;
      font-size: 0.8rem;
      font-weight: 650;
    }

    .desktop-nav a {
      color: #536058;
    }

    .desktop-nav a:hover {
      color: var(--olive);
    }

    .desktop-actions {
      gap: 0.85rem;
    }

    .desktop-actions .button {
      min-height: 42px;
      padding-inline: 0.9rem;
      font-size: 0.78rem;
    }

    .login,
    .donate-link {
      font-size: 0.78rem;
      font-weight: 750;
    }

    .donate-link {
      color: #765f2e;
    }

    .mobile-donate,
    .mobile-bottom-nav {
      display: none;
    }
  }
</style>
