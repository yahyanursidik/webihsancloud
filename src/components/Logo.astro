---
const { light = false } = Astro.props;
---

<a class:list={["logo", { light }]} href="/" aria-label="IhsanCloud, halaman utama">
  <span class="logo-window">
    <img
      src="/brand/ihsancloud-logo.png"
      width="1536"
      height="1024"
      alt="IhsanCloud"
      loading="eager"
      decoding="async"
    />
  </span>
</a>

<style>
  .logo {
    display: inline-flex;
    flex: 0 0 auto;
    align-items: center;
  }

  .logo-window {
    position: relative;
    display: block;
    overflow: hidden;
    width: 172px;
    height: 42px;
    border-radius: 0.35rem;
    background: #fff;
  }

  .logo-window img {
    position: absolute;
    top: -47px;
    left: -20px;
    width: 206px;
    max-width: none;
    height: auto;
  }

  .light {
    border: 1px solid rgba(247, 244, 236, 0.18);
    border-radius: 0.5rem;
    background: #fff;
    padding: 0.12rem 0.35rem;
  }

  @media (max-width: 440px) {
    .logo-window {
      width: 153px;
      height: 38px;
    }

    .logo-window img {
      top: -42px;
      left: -18px;
      width: 184px;
    }
  }
</style>
